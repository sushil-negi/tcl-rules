# Gemini API key — get from https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# Gemini model — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Google Doc ID containing the TCL rules (the long string in the Doc's URL)
# Example URL: https://docs.google.com/document/d/ABC123.../edit  → ID is ABC123...
GOOGLE_RULES_DOC_ID=

# Google OAuth credentials — can reuse the same values from tcl-waiver's .env.local
# The authorized account must have read access to the rules Doc.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: cache TTL in seconds for the Doc content (default 604800 = 1 week).
# Users can force a fresh pull any time with the "Refresh rules & ask" button.
# DOC_CACHE_TTL_SECONDS=604800

# Admin area (required for /admin issue tracker)
ADMIN_PASSWORD=

# Google Sheet ID where support issues are stored. Create an empty Sheet,
# share it with the OAuth account as Editor, then paste the ID here.
GOOGLE_ISSUES_SHEET_ID=

# Tournament season starts — the Saturday of Week 1 for each tournament.
# Games happen Sat–Sun; Week numbers are computed per tournament based on these dates.
# SEASON_START_REGULAR=2026-04-18
# SEASON_START_SENIORS=2026-04-25
# SEASON_START_FIREWORKS=2026-05-02
